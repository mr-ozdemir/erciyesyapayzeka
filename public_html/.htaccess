# Apache mod_rewrite'ı etkinleştir
RewriteEngine On

# Base directory'yi ayarla (gerekirse düzenleyin)
RewriteBase 

# Trailing slash'leri kaldır (opsiyonel)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} (.+)/$
RewriteRule ^ %1 [R=301,L]

# .php veya .html ile erişilirse uzantısız versiyona yönlendir
RewriteCond %{THE_REQUEST} ^GET\ /(.*)\.php(\?.*)?\ HTTP
RewriteRule (.*)\.php$ /$1 [R=301,L]

RewriteCond %{THE_REQUEST} ^GET\ /(.*)\.html(\?.*)?\ HTTP
RewriteRule (.*)\.html$ /$1 [R=301,L]

# index sayfası için özel kural (/ olarak erişim)
RewriteRule ^$ index.php [L]

# Uzantısız URL'ler için önce .php dosyasını kontrol et
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.+)$ $1.php [L,QSA]

# Eğer .php yoksa .html dosyasını kontrol et
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L,QSA]

# php -- BEGIN cPanel-generated handler, do not edit
# “ea-php81” paketini varsayılan “PHP” programlama dili olarak ayarlayın.
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php81 .php .php8 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit
